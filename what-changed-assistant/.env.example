# What Changed? Assistant - Environment Variables
# Copy this file to .env and fill in your values for local development

# ===== Jira Configuration (Local Dev) =====
# For production, these should be stored in AWS Secrets Manager
# Secret path: prod/jira/api-token, prod/jira/url, prod/jira/email

JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token-here

# ===== Confluence Configuration (Local Dev) =====
# Secret path: prod/confluence/api-token, prod/confluence/url

CONFLUENCE_URL=https://your-company.atlassian.net/wiki
CONFLUENCE_API_TOKEN=your-confluence-api-token-here

# ===== AWS Configuration =====
# AWS SSO is auto-detected from ~/.aws/config
# These are optional overrides

# AWS_SSO_START_URL=https://your-company.awsapps.com/start
# AWS_SSO_REGION=us-east-1
# AWS_REGION=us-east-1

# ===== Teleport Configuration =====
# Teleport SSO is auto-detected (tsh binary from PATH or standard locations)
# No configuration needed - login via browser when prompted

# ===== Notes =====
# - DO NOT commit .env file to git (already in .gitignore)
# - For production: use AWS Secrets Manager instead of .env
# - Run 'aws sso login --sso-session <name>' before starting
# - Run 'tsh login <cluster>' when prompted by the app
