#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: scan staged files for private/confidential information
# Runs automatically before every commit

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "Scanning staged files for sensitive information..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v 'package-lock.json' | grep -v 'node_modules/' | grep -v 'dist/' || true)

if [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}No files to scan.${NC}"
  exit 0
fi

FOUND=0

# Patterns to detect sensitive information
PATTERNS=(
  # AWS keys
  'AKIA[0-9A-Z]{16}'
  # AWS secret keys
  '[0-9a-zA-Z/+]{40}'
  # Generic API keys/tokens
  '["\x27]sk[-_][a-zA-Z0-9]{20,}["\x27]'
  # Private keys
  '-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----'
  # Passwords in config
  '[pP]assword\s*[:=]\s*["\x27][^"\x27]{4,}["\x27]'
  # Connection strings with credentials
  '://[^:]+:[^@]+@[^/]+'
  # .env variable patterns with actual values (not placeholder)
  '^[A-Z_]+=.{8,}'
  # AWS account IDs (12 digits)
  '["\x27][0-9]{12}["\x27]'
  # IP addresses (non-localhost)
  '\b(?!127\.0\.0\.1|0\.0\.0\.0|localhost)[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\b'
)

# Friendly names for each pattern
PATTERN_NAMES=(
  "AWS Access Key"
  "Potential AWS Secret Key (40-char base64)"
  "API Key/Token"
  "Private Key"
  "Hardcoded Password"
  "Connection String with Credentials"
  "Environment Variable with Value"
  "AWS Account ID"
  "IP Address"
)

# Only check high-confidence patterns to avoid false positives
HIGH_CONFIDENCE_PATTERNS=(
  'AKIA[0-9A-Z]{16}'
  '-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----'
  '[pP]assword\s*[:=]\s*["\x27][^"\x27]{8,}["\x27]'
  '://[a-zA-Z0-9_]+:[^@]+@[a-zA-Z0-9._-]+'
  '["\x27]sk[-_][a-zA-Z0-9]{20,}["\x27]'
  'PRIVATE[-_]KEY\s*[:=]\s*["\x27]'
  'SECRET\s*[:=]\s*["\x27][^"\x27]{8,}["\x27]'
  'TOKEN\s*[:=]\s*["\x27][^"\x27]{8,}["\x27]'
)

HIGH_CONFIDENCE_NAMES=(
  "AWS Access Key"
  "Private Key Block"
  "Hardcoded Password"
  "Connection String with Credentials"
  "Secret/API Key"
  "Private Key Assignment"
  "Secret Assignment"
  "Token Assignment"
)

for i in "${!HIGH_CONFIDENCE_PATTERNS[@]}"; do
  PATTERN="${HIGH_CONFIDENCE_PATTERNS[$i]}"
  NAME="${HIGH_CONFIDENCE_NAMES[$i]}"

  for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
      MATCHES=$(grep -nP "$PATTERN" "$FILE" 2>/dev/null || true)
      if [ -n "$MATCHES" ]; then
        echo -e "${RED}BLOCKED: ${NAME} detected in ${FILE}:${NC}"
        echo "$MATCHES" | head -3
        echo ""
        FOUND=1
      fi
    fi
  done
done

# Check for .env files being committed
ENV_FILES=$(echo "$STAGED_FILES" | grep -E '\.env($|\.)' || true)
if [ -n "$ENV_FILES" ]; then
  echo -e "${RED}BLOCKED: .env file(s) staged for commit:${NC}"
  echo "$ENV_FILES"
  FOUND=1
fi

# Check for common credential filenames
CRED_FILES=$(echo "$STAGED_FILES" | grep -iE '(credentials|secret|\.pem|\.key|\.p12|\.pfx|id_rsa|id_ed25519)' || true)
if [ -n "$CRED_FILES" ]; then
  echo -e "${RED}BLOCKED: Potential credential file(s) staged:${NC}"
  echo "$CRED_FILES"
  FOUND=1
fi

if [ "$FOUND" -eq 1 ]; then
  echo ""
  echo -e "${RED}Commit blocked. Review the findings above and remove sensitive data.${NC}"
  echo "To bypass (use with caution): git commit --no-verify"
  exit 1
fi

echo -e "${GREEN}No sensitive information detected. Proceeding with commit.${NC}"
exit 0
