# RDS Index Reviewer - Environment Variables
# Copy this file to .env and fill in your values

# ===== Server =====
PORT=3005

# ===== Teleport =====
# Path to tsh binary - only needed if tsh is not in PATH
# TSH_PATH=C:\Program Files\Teleport\tsh.exe

# ===== Confluence Export =====
# Optional: enable "Export to Confluence" from the results screen
# CONFLUENCE_URL=https://your-company.atlassian.net
# CONFLUENCE_EMAIL=you@company.com
# CONFLUENCE_API_TOKEN=your_api_token
# Or load the Atlassian token from AWS Secrets Manager instead of storing it in .env
# CONFLUENCE_API_TOKEN_SECRET_NAME=jira_token
# CONFLUENCE_API_TOKEN_SECRET_REGION=us-east-1
# CONFLUENCE_SPACE_KEY=EDT
# CONFLUENCE_PARENT_PAGE_ID=7493847876

# ===== Notes =====
# - DO NOT commit .env to git (already in .gitignore)
# - performance_schema must be enabled on target RDS instances (default on AWS RDS)
# - Teleport must be configured with database access for your RDS instances
# - Confluence export creates/uses an "RDS Index Reviewer" page under CONFLUENCE_PARENT_PAGE_ID
# - Dated report exports are created as child pages under that tool page
