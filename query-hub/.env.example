# Query Hub API — install & usage (Windows + macOS): README.md in this folder
# (server/src/tools/query-hub/README.md)
PORT=3003

# SSO device login (same as main EDT Hub): profile passed to `aws sso login --profile …` for the initial session
# QUERY_HUB_SSO_DEVICE_PROFILE=default

# Optional (EC2 / API host): IAM Identity Center portal — used when auto-creating `rds-dba-<accountId>` profiles
# (Kiro Replica Lag style) and there is no shared `sso_session` in ~/.aws/config yet.
# Quote the value so `#` in the URL is not treated as a comment by dotenv.
# AWS_SSO_START_URL="https://d-9067ba615a.awsapps.com/start/#"
# AWS_SSO_REGION=us-east-1

# Optional: full path to tsh.exe (Windows) or tsh (Mac/Linux) if not on PATH — same machine as this API
# QUERY_HUB_TSH_PATH=C:\Program Files\Teleport Connect\tsh.exe

# --- AI backend (choose one primary path) ---
# If QUERY_HUB_BEDROCK_MODEL_ID is unset, the API tries Kiro CLI first (auto). To disable that fallback:
# QUERY_HUB_DISABLE_KIRO_CLI_FALLBACK=true

# A) Kiro CLI only (explicit)
# QUERY_HUB_USE_KIRO_CLI=true
# QUERY_HUB_KIRO_CLI_PATH=kiro-cli
# QUERY_HUB_KIRO_WORKDIR=
# QUERY_HUB_KIRO_CLI_TIMEOUT_MS=180000

# B) Amazon Bedrock (default) — required model ID (admin); account + SSO come from the UI (same flow as RDS Replica Lag)
# Examples (use what your org enabled in Bedrock): anthropic.claude-3-5-sonnet-20240620-v1:0
# or inference profile ARNs / IDs from the Bedrock console.
QUERY_HUB_BEDROCK_MODEL_ID=

# Optional: Bedrock lives in a different AWS account than your Teleport RDS (e.g. par-ai non-prod).
# When set, Kiro always uses SSO profile rds-dba-<this account id> for Bedrock, ignoring the DB account from Teleport.
# QUERY_HUB_BEDROCK_ACCOUNT_ID=123456789012

# Optional: headless API only — fixed SSO profile instead of account picker in the UI
# QUERY_HUB_BEDROCK_PROFILE=my-sso-profile
# QUERY_HUB_BEDROCK_REGION=us-east-1

# Optional: work-email sign-in for AI (unlocks team keys above without pasting API keys in the browser)
# QUERY_HUB_EMAIL_AUTH=true
# QUERY_HUB_JWT_SECRET=use-a-long-random-string-at-least-32-chars
# Allow either whole addresses or a domain:
# QUERY_HUB_ALLOWED_EMAILS=dba1@partech.com,dba2@partech.com
# — or —
# QUERY_HUB_EMAIL_DOMAIN=partech.com
# Dev: log 6-digit codes to the API terminal (set true in prod only if you accept console leakage)
# QUERY_HUB_EMAIL_LOG_CODES=true
